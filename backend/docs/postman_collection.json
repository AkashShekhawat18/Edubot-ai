			"name": "Login",
			"item": [
				{
					"name": "Login — Success (Teacher)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"username\": \"teacher1\", \"password\": \"password123\"}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response has success status', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.status).to.eql('success');",
									"    pm.expect(json.user.role).to.eql('teacher');",
									"    pm.expect(json.user.username).to.eql('teacher1');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
